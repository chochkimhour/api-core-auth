{
  "name": "api-core-auth",
  "version": "1.0.1",
  "description": "Secure opaque token authentication for Node.js, Express, JavaScript, and TypeScript APIs with password helpers, middleware, errors, and types.",
  "type": "module",
  "license": "MIT",
  "author": "Choch Kimhour",
  "homepage": "https://www.npmjs.com/package/api-core-auth",
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.com/chochkimhour/api-core-auth.git"
  },
  "bugs": {
    "url": "https://gitlab.com/chochkimhour/api-core-auth/-/issues"
  },
  "keywords": [
    "auth",
    "authentication",
    "authorization",
    "opaque",
    "opaque-token",
    "opaque-tokens",
    "secure-token",
    "secure-auth",
    "token-auth",
    "session-token",
    "api-token",
    "api-key",
    "token",
    "tokens",
    "session",
    "sessions",
    "login",
    "password",
    "password-hashing",
    "bcrypt",
    "bcryptjs",
    "express",
    "express-auth",
    "middleware",
    "node",
    "nodejs",
    "typescript",
    "javascript",
    "api",
    "rest-api",
    "backend",
    "security",
    "open-source"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3"
  },
  "peerDependencies": {
    "express": ">=4.17.0 || >=5.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.1",
    "@types/node": "^22.14.1",
    "eslint": "^9.25.1",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0",
    "vitest": "^3.1.2"
  }
}